{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/github",
      "destination": "https://github.com/vmkteam/pgdesigner.io",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
