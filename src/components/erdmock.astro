---
// SVG mock of an ERD canvas — used in hero section as product visual
---

<svg viewBox="0 0 640 400" xmlns="http://www.w3.org/2000/svg" class="erd-mock" role="img" aria-label="PgDesigner ERD canvas showing database tables with foreign key relationships">
	<defs>
		<pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
			<path d="M 20 0 L 0 0 0 20" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="0.5"/>
		</pattern>
		<filter id="glow">
			<feGaussianBlur stdDeviation="2" result="blur"/>
			<feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
		</filter>
	</defs>
	<rect width="640" height="400" fill="#111318"/>
	<rect width="640" height="400" fill="url(#grid)"/>

	<!-- Table: users -->
	<g transform="translate(40, 30)">
		<rect width="150" height="130" rx="6" fill="#1a1d24" stroke="#2563eb" stroke-width="1.2"/>
		<rect width="150" height="26" rx="6" fill="#2563eb"/>
		<rect x="0" y="20" width="150" height="8" fill="#2563eb"/>
		<text x="12" y="18" fill="#fff" font-size="11" font-weight="600" font-family="system-ui">users</text>
		<text x="12" y="46" fill="#60a5fa" font-size="9" font-family="monospace">id</text>
		<text x="105" y="46" fill="#6b7280" font-size="8" font-family="monospace">bigint</text>
		<text x="12" y="62" fill="#d1d5db" font-size="9" font-family="monospace">email</text>
		<text x="105" y="62" fill="#6b7280" font-size="8" font-family="monospace">text</text>
		<text x="12" y="78" fill="#d1d5db" font-size="9" font-family="monospace">name</text>
		<text x="105" y="78" fill="#6b7280" font-size="8" font-family="monospace">text</text>
		<text x="12" y="94" fill="#d1d5db" font-size="9" font-family="monospace">created_at</text>
		<text x="105" y="94" fill="#6b7280" font-size="8" font-family="monospace">tstz</text>
		<text x="12" y="110" fill="#d1d5db" font-size="9" font-family="monospace">status_id</text>
		<text x="105" y="110" fill="#6b7280" font-size="8" font-family="monospace">int</text>
		<rect x="130" y="36" width="14" height="13" rx="2" fill="#f59e0b" opacity="0.9"/>
		<text x="132" y="46" fill="#111318" font-size="7" font-weight="700" font-family="system-ui">PK</text>
	</g>

	<!-- Table: orders -->
	<g transform="translate(280, 55)">
		<rect width="150" height="130" rx="6" fill="#1a1d24" stroke="#2563eb" stroke-width="1.2"/>
		<rect width="150" height="26" rx="6" fill="#2563eb"/>
		<rect x="0" y="20" width="150" height="8" fill="#2563eb"/>
		<text x="12" y="18" fill="#fff" font-size="11" font-weight="600" font-family="system-ui">orders</text>
		<text x="12" y="46" fill="#60a5fa" font-size="9" font-family="monospace">id</text>
		<text x="105" y="46" fill="#6b7280" font-size="8" font-family="monospace">bigint</text>
		<text x="12" y="62" fill="#d1d5db" font-size="9" font-family="monospace">user_id</text>
		<text x="105" y="62" fill="#6b7280" font-size="8" font-family="monospace">bigint</text>
		<text x="12" y="78" fill="#d1d5db" font-size="9" font-family="monospace">total</text>
		<text x="105" y="78" fill="#6b7280" font-size="8" font-family="monospace">numeric</text>
		<text x="12" y="94" fill="#d1d5db" font-size="9" font-family="monospace">status</text>
		<text x="105" y="94" fill="#6b7280" font-size="8" font-family="monospace">enum</text>
		<text x="12" y="110" fill="#d1d5db" font-size="9" font-family="monospace">ordered_at</text>
		<text x="105" y="110" fill="#6b7280" font-size="8" font-family="monospace">tstz</text>
		<rect x="130" y="36" width="14" height="13" rx="2" fill="#f59e0b" opacity="0.9"/>
		<text x="132" y="46" fill="#111318" font-size="7" font-weight="700" font-family="system-ui">PK</text>
		<rect x="130" y="52" width="14" height="13" rx="2" fill="#2563eb" opacity="0.8"/>
		<text x="132" y="62" fill="#fff" font-size="7" font-weight="700" font-family="system-ui">FK</text>
	</g>

	<!-- Table: order_items -->
	<g transform="translate(480, 15)">
		<rect width="140" height="114" rx="6" fill="#1a1d24" stroke="#2563eb" stroke-width="1.2"/>
		<rect width="140" height="26" rx="6" fill="#2563eb"/>
		<rect x="0" y="20" width="140" height="8" fill="#2563eb"/>
		<text x="12" y="18" fill="#fff" font-size="11" font-weight="600" font-family="system-ui">order_items</text>
		<text x="12" y="46" fill="#60a5fa" font-size="9" font-family="monospace">id</text>
		<text x="95" y="46" fill="#6b7280" font-size="8" font-family="monospace">bigint</text>
		<text x="12" y="62" fill="#d1d5db" font-size="9" font-family="monospace">order_id</text>
		<text x="95" y="62" fill="#6b7280" font-size="8" font-family="monospace">bigint</text>
		<text x="12" y="78" fill="#d1d5db" font-size="9" font-family="monospace">product_id</text>
		<text x="95" y="78" fill="#6b7280" font-size="8" font-family="monospace">bigint</text>
		<text x="12" y="94" fill="#d1d5db" font-size="9" font-family="monospace">qty</text>
		<text x="95" y="94" fill="#6b7280" font-size="8" font-family="monospace">int</text>
	</g>

	<!-- Table: products -->
	<g transform="translate(460, 195)">
		<rect width="155" height="146" rx="6" fill="#1a1d24" stroke="#2563eb" stroke-width="1.2"/>
		<rect width="155" height="26" rx="6" fill="#2563eb"/>
		<rect x="0" y="20" width="155" height="8" fill="#2563eb"/>
		<text x="12" y="18" fill="#fff" font-size="11" font-weight="600" font-family="system-ui">products</text>
		<text x="12" y="46" fill="#60a5fa" font-size="9" font-family="monospace">id</text>
		<text x="110" y="46" fill="#6b7280" font-size="8" font-family="monospace">bigint</text>
		<text x="12" y="62" fill="#d1d5db" font-size="9" font-family="monospace">name</text>
		<text x="110" y="62" fill="#6b7280" font-size="8" font-family="monospace">text</text>
		<text x="12" y="78" fill="#d1d5db" font-size="9" font-family="monospace">price</text>
		<text x="110" y="78" fill="#6b7280" font-size="8" font-family="monospace">numeric</text>
		<text x="12" y="94" fill="#d1d5db" font-size="9" font-family="monospace">category_id</text>
		<text x="110" y="94" fill="#6b7280" font-size="8" font-family="monospace">int</text>
		<text x="12" y="110" fill="#d1d5db" font-size="9" font-family="monospace">sku</text>
		<text x="110" y="110" fill="#6b7280" font-size="8" font-family="monospace">text</text>
		<text x="12" y="126" fill="#d1d5db" font-size="9" font-family="monospace">active</text>
		<text x="110" y="126" fill="#6b7280" font-size="8" font-family="monospace">bool</text>
	</g>

	<!-- Table: statuses -->
	<g transform="translate(60, 235)">
		<rect width="130" height="82" rx="6" fill="#1a1d24" stroke="#2563eb" stroke-width="1.2"/>
		<rect width="130" height="26" rx="6" fill="#2563eb"/>
		<rect x="0" y="20" width="130" height="8" fill="#2563eb"/>
		<text x="12" y="18" fill="#fff" font-size="11" font-weight="600" font-family="system-ui">statuses</text>
		<text x="12" y="46" fill="#60a5fa" font-size="9" font-family="monospace">id</text>
		<text x="90" y="46" fill="#6b7280" font-size="8" font-family="monospace">int</text>
		<text x="12" y="62" fill="#d1d5db" font-size="9" font-family="monospace">name</text>
		<text x="90" y="62" fill="#6b7280" font-size="8" font-family="monospace">text</text>
	</g>

	<!-- Table: categories -->
	<g transform="translate(265, 260)">
		<rect width="140" height="98" rx="6" fill="#1a1d24" stroke="#2563eb" stroke-width="1.2"/>
		<rect width="140" height="26" rx="6" fill="#2563eb"/>
		<rect x="0" y="20" width="140" height="8" fill="#2563eb"/>
		<text x="12" y="18" fill="#fff" font-size="11" font-weight="600" font-family="system-ui">categories</text>
		<text x="12" y="46" fill="#60a5fa" font-size="9" font-family="monospace">id</text>
		<text x="100" y="46" fill="#6b7280" font-size="8" font-family="monospace">int</text>
		<text x="12" y="62" fill="#d1d5db" font-size="9" font-family="monospace">name</text>
		<text x="100" y="62" fill="#6b7280" font-size="8" font-family="monospace">text</text>
		<text x="12" y="78" fill="#d1d5db" font-size="9" font-family="monospace">parent_id</text>
		<text x="100" y="78" fill="#6b7280" font-size="8" font-family="monospace">int</text>
	</g>

	<!-- FK relationship lines -->
	<g filter="url(#glow)" opacity="0.8">
		<!-- users -> orders (user_id) -->
		<path d="M 190 88 C 235 88, 235 117, 280 117" fill="none" stroke="#3b82f6" stroke-width="1.5"/>
		<circle cx="190" cy="88" r="3" fill="#3b82f6"/>
		<polygon points="277,114 283,117 277,120" fill="#3b82f6"/>

		<!-- orders -> order_items (order_id) -->
		<path d="M 430 103 C 455 103, 455 77, 480 77" fill="none" stroke="#3b82f6" stroke-width="1.5"/>
		<circle cx="430" cy="103" r="3" fill="#3b82f6"/>
		<polygon points="477,74 483,77 477,80" fill="#3b82f6"/>

		<!-- products -> order_items (product_id) -->
		<path d="M 538 195 C 538 155, 545 95, 545 95" fill="none" stroke="#3b82f6" stroke-width="1.5"/>
		<circle cx="538" cy="195" r="3" fill="#3b82f6"/>
		<polygon points="542,98 545,92 548,98" fill="#3b82f6"/>

		<!-- statuses -> users (status_id) -->
		<path d="M 125 235 C 125 205, 115 178, 115 160" fill="none" stroke="#3b82f6" stroke-width="1.5"/>
		<circle cx="125" cy="235" r="3" fill="#3b82f6"/>
		<polygon points="112,163 115,157 118,163" fill="#3b82f6"/>

		<!-- categories -> products (category_id) -->
		<path d="M 405 293 C 430 293, 445 290, 460 290" fill="none" stroke="#3b82f6" stroke-width="1.5"/>
		<circle cx="405" cy="293" r="3" fill="#3b82f6"/>
		<polygon points="457,287 463,290 457,293" fill="#3b82f6"/>
	</g>

	<!-- Minimap (bottom-right) -->
	<g opacity="0.6">
		<rect x="560" y="352" width="72" height="42" rx="4" fill="rgba(17,19,24,0.95)" stroke="rgba(255,255,255,0.08)" stroke-width="0.5"/>
		<rect x="565" y="357" width="8" height="6" rx="1" fill="#2563eb" opacity="0.4"/>
		<rect x="576" y="359" width="8" height="6" rx="1" fill="#2563eb" opacity="0.4"/>
		<rect x="587" y="356" width="7" height="5" rx="1" fill="#2563eb" opacity="0.4"/>
		<rect x="571" y="368" width="7" height="5" rx="1" fill="#2563eb" opacity="0.4"/>
		<rect x="583" y="366" width="8" height="7" rx="1" fill="#2563eb" opacity="0.4"/>
		<rect x="565" y="370" width="5" height="4" rx="1" fill="#2563eb" opacity="0.4"/>
		<rect x="564" y="355" width="30" height="20" rx="2" fill="none" stroke="#3b82f6" stroke-width="1" opacity="0.7"/>
	</g>
</svg>
