---
import Container from "@/components/container.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import { Icon } from "astro-icon/components";

const menuitems = [
  { title: "Features", path: "/features", section: "features" },
  { title: "Compare", path: "/compare", section: "compare" },
  { title: "Pricing", path: "/pricing", section: "pricing" },
  { title: "Docs", path: "/docs/quickstart", section: "docs" },
  { title: "Blog", path: "/blog", section: "blog" },
];

const currentPath = Astro.url.pathname;
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="flex items-center gap-1.5">
          <svg width="36" height="36" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="14" y="14" width="36" height="36" rx="10" fill="#2F5D7C"/>
            <rect x="22" y="24" width="20" height="3" rx="1.5" fill="#FFFFFF"/>
            <rect x="22" y="30" width="14" height="3" rx="1.5" fill="#FFFFFF" opacity="0.7"/>
            <rect x="22" y="36" width="18" height="3" rx="1.5" fill="#FFFFFF" opacity="0.4"/>
          </svg>
          <span class="text-xl font-bold text-heading">PgDesigner</span>
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 text-body" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          {menuitems.map((item) => {
            const isActive = currentPath.startsWith("/" + item.section);
            return (
              <li>
                <a
                  href={item.path}
                  class:list={[
                    "flex lg:px-3 py-2 items-center transition-colors",
                    isActive ? "text-heading font-medium" : "text-body hover:text-heading",
                  ]}>
                  <span>{item.title}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </MenuItems>
    </Astronav>
    <div>
      <div class="hidden lg:flex items-center gap-4">
        <button
          id="theme-toggle"
          type="button"
          class="text-muted hover:text-heading transition-colors"
          aria-label="Toggle theme">
          <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
          </svg>
          <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
          </svg>
        </button>
        <a
          href="https://github.com/vmkteam/pgdesigner"
          target="_blank"
          rel="noopener"
          class="text-muted hover:text-heading transition-colors"
          aria-label="GitHub">
          <Icon name="simple-icons:github" class="w-5 h-5" />
        </a>
        <a
          href="https://demo.pgdesigner.io"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border border-border-default px-4 py-2 text-sm font-semibold text-body hover:bg-surface-alt transition-colors">
          Try Demo
        </a>
        <a
          href="/docs/download"
          class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-500 transition-colors">
          Download Free
        </a>
      </div>
    </div>
  </header>
</Container>

<script>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });
</script>
