---
import { Dropdown as DropdownContainer, DropdownItems } from "astro-navbar";
const { title, lastItem, children } = Astro.props;
---

<li class="relative">
  <DropdownContainer class="group">
    <button
      class="flex items-center gap-1 w-full lg:w-auto lg:px-3 py-2 text-body hover:text-heading">
      <span>{title}</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="3"
        stroke="currentColor"
        class="w-3 h-3 mt-0.5 group-open:rotate-180 transition-transform duration-150">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
      </svg>
    </button>
    <DropdownItems>
      <div
        class:list={[
          "lg:absolute w-full lg:w-56 z-10 lg:pt-2",
          lastItem
            ? "lg:right-0 origin-top-right"
            : "lg:left-0 origin-top-left",
        ]}>
        <div
          style="background:#1a1f2e;border:1px solid rgba(255,255,255,0.08);border-radius:0.75rem;box-shadow:0 20px 50px rgba(0,0,0,0.4);padding:0.5rem;display:flex;flex-direction:column;">
          {
            children.map((item) => (
              <a
                href={item.path}
                style="padding:0.5rem 0.75rem;font-size:0.875rem;color:#9ca3af;text-decoration:none;border-radius:0.375rem;transition:color 150ms,background 150ms;"
                onmouseover="this.style.color='#fff';this.style.background='rgba(255,255,255,0.06)'"
                onmouseout="this.style.color='#9ca3af';this.style.background='transparent'">
                {item.title}
              </a>
            ))
          }
        </div>
      </div>
    </DropdownItems>
  </DropdownContainer>
</li>
