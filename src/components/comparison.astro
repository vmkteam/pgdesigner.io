---
import Container from "@/components/container.astro";

const rows = [
  { feature: "PG-specialized", pg: true, pgm: true, draw: false, atlas: false },
  { feature: "Git-friendly format", pg: true, pgm: false, draw: false, atlas: true },
  { feature: "Diff/ALTER engine", pg: true, pgm: true, draw: false, atlas: "Partial" },
  { feature: "Hazard detection", pg: true, pgm: false, draw: false, atlas: "Partial" },
  { feature: "66 lint rules", pg: true, pgm: "Basic", draw: false, atlas: "3 rules" },
  { feature: "Sample data generator", pg: true, pgm: false, draw: false, atlas: false },
  { feature: "Visual ERD", pg: true, pgm: "Partial", draw: true, atlas: false },
  { feature: "Price (individual)", pg: "$19", pgm: "$49.90", draw: "Free", atlas: "$9/dev/mo" },
];

function renderCell(val: boolean | string) {
  if (val === true) return { text: "Yes", cls: "text-positive font-medium" };
  if (val === false) return { text: "—", cls: "text-faint" };
  return { text: val, cls: "text-muted" };
}
---

<Container>
  <div class="mt-24 mb-8">
    <h2 class="text-3xl lg:text-4xl font-bold text-center text-heading mb-3">
      How PgDesigner Compares
    </h2>
    <p class="text-center text-muted mb-10 max-w-lg mx-auto">
      The only tool that combines PG specialization, git-friendly format, diff engine, and modern visual UI.
    </p>
    <div class="overflow-x-auto rounded-xl border border-border-default">
      <table class="w-full text-sm">
        <caption class="sr-only">Feature comparison: PgDesigner vs pgModeler, DrawDB, and Atlas CE</caption>
        <thead>
          <tr class="bg-surface-alt">
            <th class="py-3.5 px-5 text-left font-semibold text-heading">Feature</th>
            <th class="py-3.5 px-5 text-center font-semibold text-accent-text">PgDesigner</th>
            <th class="py-3.5 px-5 text-center font-semibold text-muted">pgModeler</th>
            <th class="py-3.5 px-5 text-center font-semibold text-muted">DrawDB</th>
            <th class="py-3.5 px-5 text-center font-semibold text-muted">Atlas CE</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => {
            const cells = [
              { val: row.pg, highlight: true },
              { val: row.pgm, highlight: false },
              { val: row.draw, highlight: false },
              { val: row.atlas, highlight: false },
            ];
            return (
              <tr class:list={["border-t border-border-default", i % 2 !== 0 && "bg-surface-alt"]}>
                <td class="py-3 px-5 font-medium text-body">{row.feature}</td>
                {cells.map((cell) => {
                  const { text, cls } = renderCell(cell.val);
                  return (
                    <td class:list={["py-3 px-5 text-center", cell.highlight ? "!font-semibold !text-heading" : cls]}>
                      {cell.highlight && cell.val === true ? (
                        <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green-500 text-white text-xs">✓</span>
                      ) : cell.highlight ? (
                        <span class="text-heading font-semibold">{text}</span>
                      ) : text}
                    </td>
                  );
                })}
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
</Container>
