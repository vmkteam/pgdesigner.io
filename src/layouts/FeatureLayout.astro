---
import Layout from "./Layout.astro";
import Container from "@/components/container.astro";
import Subnav from "@/components/subnav.astro";
import { featurePages } from "@/data/navigation";

interface Props {
  title: string;
  description: string;
  subtitle?: string;
}

const { title, description, subtitle } = Astro.props;
---

<Layout title={title} description={description}>
  <Subnav items={featurePages} />

  <Container>
    <div class="max-w-3xl mx-auto pt-16 pb-24">
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-heading">
        {title}
      </h1>
      {subtitle && (
        <p class="mt-4 text-lg text-body">{subtitle}</p>
      )}

      <div class="mt-12 prose max-w-none
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3
        prose-p:leading-relaxed
        prose-headings:font-semibold">
        <slot />
      </div>

      <div class="mt-16 flex gap-4">
        <a href="/docs/download" class="inline-flex items-center rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-blue-500 transition-colors">
          Download Free
        </a>
        <a href="/features" class="inline-flex items-center rounded-lg border border-border-default px-5 py-2.5 text-sm font-semibold text-body hover:bg-surface-alt/50 transition-colors">
          All Features
        </a>
      </div>
    </div>
  </Container>
</Layout>
