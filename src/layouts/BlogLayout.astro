---
import Container from "@/components/container.astro";
import { getFormattedDate } from "@/utils/all";
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} description={frontmatter.snippet}>
  <Container>
    <div class="mx-auto max-w-3xl mt-14">
      <span class="text-accent-text uppercase tracking-wider text-sm font-medium">
        {frontmatter.category}
      </span>
      <h1
        class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-1 lg:leading-tight text-heading">
        {frontmatter.title}
      </h1>
      <div class="flex gap-2 mt-3 items-center flex-wrap md:flex-nowrap">
        <span class="text-muted">
          {frontmatter.author}
        </span>
        <span class="text-muted">•</span>
        <time class="text-muted" datetime={frontmatter.publishDate}>
          {getFormattedDate(frontmatter.publishDate)}
        </time>
        <span class="text-muted hidden md:block">•</span>
        <div class="w-full md:w-auto flex flex-wrap gap-3">
          {
            frontmatter.tags.map((tag) => (
              <span class="text-sm text-faint">#{tag}</span>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-3xl mt-8 prose prose-lg
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3
      prose-p:leading-relaxed
      prose-headings:font-semibold">
      <slot />
    </div>

    <div class="max-w-3xl mx-auto text-center mt-12">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm text-accent-text hover:underline">
        ← Back to Blog
      </a>
    </div>
  </Container>
</Layout>
