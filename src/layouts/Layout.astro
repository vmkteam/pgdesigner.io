---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
// Inter font loaded via global.css with font-display: optional (no FOUT)
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title, description } = Astro.props;

const makeTitle = title
  ? title + " | PgDesigner"
  : "PgDesigner — Visual PostgreSQL Schema Designer";

const seoDescription = description || "Design PostgreSQL schemas visually. Generate production-ready SQL. Compare schemas with safe ALTER migrations. 75 lint rules. Free for non-commercial use.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#2F5D7C" />
    <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      const theme = localStorage.getItem("theme");
      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
    </script>

    <SEO
      title={makeTitle}
      description={seoDescription}
      canonical={canonicalURL}
      twitter={{
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "PgDesigner — Visual PostgreSQL Schema Designer",
        },
      }}
    />
    <script type="application/ld+json" is:inline>
    [
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "PgDesigner",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "macOS, Windows, Linux",
        "description": "Visual PostgreSQL schema designer with ERD editor, DDL generation, schema diff, ALTER migrations, 75 lint rules, and CLI.",
        "url": "https://pgdesigner.io",
        "offers": [
          {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD",
            "description": "Free for non-commercial use"
          },
          {
            "@type": "Offer",
            "price": "19",
            "priceCurrency": "USD",
            "description": "Individual license, one-time payment"
          }
        ],
        "screenshot": "https://pgdesigner.io/images/light.png",
        "softwareVersion": "1.0",
        "author": {
          "@type": "Organization",
          "name": "vmkteam",
          "url": "https://github.com/vmkteam"
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "vmkteam",
        "url": "https://github.com/vmkteam",
        "logo": "https://pgdesigner.io/favicon.svg"
      }
    ]
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HFQ9KWZNVN" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HFQ9KWZNVN');
    </script>
  </head>
  <body class="bg-surface text-body antialiased">
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
    <script is:inline>
      document.querySelectorAll('a[href^="http"]').forEach(a => {
        if (!a.hostname || a.hostname === location.hostname) return;
        a.setAttribute('target', '_blank');
        a.setAttribute('rel', 'noopener');
      });
    </script>
    <script is:inline>
      document.addEventListener('click', (e) => {
        const zoom = e.target.closest('.img-zoom');
        if (!zoom) return;
        const img = zoom.querySelector('img');
        if (!img) return;
        const overlay = document.createElement('div');
        overlay.className = 'img-zoom-overlay';
        overlay.innerHTML = '<img src="' + img.src + '" alt="' + (img.alt || '') + '">';
        function esc(e) {
          if (e.key === 'Escape') close();
        }
        function close() {
          overlay.remove();
          document.removeEventListener('keydown', esc);
        }
        overlay.addEventListener('click', close);
        document.addEventListener('keydown', esc);
        document.body.appendChild(overlay);
      });
    </script>
  </body>
</html>
