---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

const plans = [
  {
    name: "Free",
    price: "$0",
    period: "forever",
    description: "Non-commercial, personal, education, research, open-source.",
    features: [
      "All features — no limits",
      "Non-commercial use only",
      "Build from source (Go + pnpm)",
      "Community support (GitHub Issues)",
    ],
    cta: { text: "Download Free", href: "/docs/download" },
    highlight: false,
  },
  {
    name: "Individual",
    price: "$19",
    period: "one-time",
    description: "Commercial use for a single developer.",
    popular: true,
    features: [
      "All features — no limits",
      "Commercial use licensed",
      "Signed binaries (macOS notarized)",
      "1 year of updates included",
      "Renewal: $9/yr (optional)",
    ],
    cta: { text: "Buy License", href: "https://buy.stripe.com/3cIeVebKad9De9k75R33W00" },
    highlight: true,
  },
  {
    name: "Team",
    price: "$49",
    period: "one-time",
    description: "Commercial use for up to 5 developers.",
    features: [
      "All features — no limits",
      "Commercial use (up to 5 devs)",
      "Signed binaries",
      "1 year of updates included",
      "Renewal: $29/yr (optional)",
    ],
    cta: { text: "Buy License", href: "https://buy.stripe.com/dRmdRa01sb1v5CO4XJ33W02" },
    highlight: false,
  },
  {
    name: "Enterprise",
    price: "$149",
    period: "/yr",
    description: "Unlimited developers, priority support.",
    features: [
      "All features — no limits",
      "Unlimited developers",
      "Signed binaries",
      "Continuous updates",
      "Priority email support",
    ],
    cta: { text: "Buy License", href: "https://buy.stripe.com/8x200keWm5Hbe9k61N33W01" },
    highlight: false,
  },
];

const faqs = [
  {
    q: "What counts as commercial use?",
    a: "Any use in a company or organization that generates revenue. Freelancers billing clients also need a commercial license. Non-profits and educational institutions can use the Free tier.",
  },
  {
    q: "What if I don't renew updates?",
    a: "Your current version works forever — no lock-out, no time-bomb, no license expiry. You just won't receive new releases. When you're ready, renew and get all updates since your last renewal.",
  },
  {
    q: "Can I build from source for free?",
    a: "Yes. The source code is available under PolyForm Noncommercial. You need Go 1.22+ and pnpm to build. The $19 license is about convenience (signed binaries, brew install) and commercial rights.",
  },
  {
    q: "Is there a trial?",
    a: "The Free tier IS the trial — all features, no time limit, no feature gates. The only restriction is commercial use. Try it for as long as you want.",
  },
  {
    q: "How does this compare to competitors?",
    a: "pgModeler: from $49.90 per version. Atlas Pro: $9/dev/mo + $59/CI/mo. dbdiagram.io Pro: $9/mo per user. DbSchema: $147 perpetual. PgDesigner: $19 once.",
  },
  {
    q: "Do you offer refunds?",
    a: "Yes, 30-day money-back guarantee. If PgDesigner doesn't work for your use case, email us and we'll refund — no questions asked.",
  },
  {
    q: "Where is my data stored?",
    a: "On your machine. PgDesigner is offline-first — no cloud account, no telemetry, no phone-home. Your .pgd files live in your git repository.",
  },
];
---

<Layout title="Pricing — PostgreSQL Schema Designer" description="PgDesigner pricing: free for non-commercial use forever. $19 one-time for individuals, $49 for teams. All features in every plan. No subscriptions, no feature gates.">
  <Container>
    <div class="max-w-5xl mx-auto pt-16 pb-24">
      <div class="text-center">
        <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-heading">
          Simple, honest pricing
        </h1>
        <p class="mt-4 text-lg text-body max-w-2xl mx-auto">
          Every plan includes all features — 66 lint rules, diff engine, sample data, CLI. Pay only for commercial use.
        </p>
      </div>

      <!-- Plans grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 mt-14">
        {plans.map((plan) => (
          <div class:list={[
            "rounded-xl p-6 flex flex-col relative",
            plan.highlight
              ? "bg-blue-600/10 border-2 border-blue-500/50 ring-1 ring-blue-500/20"
              : "bg-surface-alt border border-border-default",
          ]}>
            {plan.popular && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 text-[10px] font-bold uppercase tracking-wider bg-blue-600 text-white px-3 py-0.5 rounded-full">
                Most popular
              </span>
            )}
            <div>
              <h2 class="text-lg font-semibold text-heading">{plan.name}</h2>
              <div class="mt-3 flex items-baseline gap-1">
                <span class="text-4xl font-bold text-heading">{plan.price}</span>
                <span class="text-sm text-muted">{plan.period}</span>
              </div>
              <p class="mt-2 text-sm text-muted">{plan.description}</p>
            </div>
            <ul class="mt-6 space-y-2.5 flex-1">
              {plan.features.map((f) => (
                <li class="flex gap-2 text-sm text-body">
                  <span class="text-positive mt-0.5 shrink-0">✓</span>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href={plan.cta.href}
              class:list={[
                "mt-6 inline-flex items-center justify-center rounded-lg px-4 py-2.5 text-sm font-semibold transition-colors",
                plan.highlight
                  ? "bg-blue-600 text-white hover:bg-blue-500"
                  : "bg-surface-alt border border-border-default text-heading hover:bg-surface-alt/80",
              ]}>
              {plan.cta.text}
            </a>
          </div>
        ))}
      </div>

      <!-- Competitor pricing comparison -->
      <div class="mt-16 text-center">
        <h2 class="text-2xl font-bold text-heading mb-6">How our pricing compares</h2>
        <div class="overflow-x-auto">
          <table class="w-full max-w-2xl mx-auto text-sm">
            <thead>
              <tr class="border-b border-border-default">
                <th class="py-3 px-4 text-left font-semibold text-heading">Tool</th>
                <th class="py-3 px-4 text-center font-semibold text-heading">Individual</th>
                <th class="py-3 px-4 text-center font-semibold text-heading">Team (5 devs, 1yr)</th>
              </tr>
            </thead>
            <tbody class="text-body">
              <tr class="border-b border-border-default bg-blue-600/5">
                <td class="py-2.5 px-4 font-semibold text-heading">PgDesigner</td>
                <td class="py-2.5 px-4 text-center font-semibold text-heading">$19 once</td>
                <td class="py-2.5 px-4 text-center font-semibold text-heading">$49 once</td>
              </tr>
              <tr class="border-b border-border-default">
                <td class="py-2.5 px-4">pgModeler</td>
                <td class="py-2.5 px-4 text-center">from $49.90</td>
                <td class="py-2.5 px-4 text-center">~$250</td>
              </tr>
              <tr class="border-b border-border-default">
                <td class="py-2.5 px-4">Atlas Pro</td>
                <td class="py-2.5 px-4 text-center">$9/dev/mo</td>
                <td class="py-2.5 px-4 text-center">$540+/yr</td>
              </tr>
              <tr class="border-b border-border-default">
                <td class="py-2.5 px-4">dbdiagram.io Pro</td>
                <td class="py-2.5 px-4 text-center">$9/mo</td>
                <td class="py-2.5 px-4 text-center">$540/yr</td>
              </tr>
              <tr class="border-b border-border-default">
                <td class="py-2.5 px-4">DbSchema</td>
                <td class="py-2.5 px-4 text-center">$147</td>
                <td class="py-2.5 px-4 text-center">$735</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Trust signals -->
      <div class="mt-16 grid sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
        <div class="text-center">
          <p class="text-2xl font-bold text-heading">No subscriptions</p>
          <p class="text-sm text-muted mt-1">Pay once. Use forever. Renew updates only when you want to.</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-heading">No feature gates</p>
          <p class="text-sm text-muted mt-1">Free tier has the same features as paid. Only commercial use requires a license.</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-heading">Your data, your machine</p>
          <p class="text-sm text-muted mt-1">Offline-first. No cloud account. No telemetry. Files live in your git repo.</p>
        </div>
      </div>

      <!-- FAQ -->
      <div class="mt-20 max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-heading text-center mb-8">Frequently asked questions</h2>
        <div class="space-y-6">
          {faqs.map(({ q, a }) => (
            <div class="border-b border-border-default pb-5">
              <h3 class="font-semibold text-heading">{q}</h3>
              <p class="mt-2 text-sm text-body leading-relaxed">{a}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 pt-6 border-t border-border-default">
          <p class="text-sm font-semibold text-heading mb-3">Explore more</p>
          <div class="flex flex-wrap gap-3">
            <a href="/features" class="text-sm text-accent-text hover:underline">All Features →</a>
            <a href="/compare/pgmodeler" class="text-sm text-accent-text hover:underline">PgDesigner vs pgModeler →</a>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Layout>
